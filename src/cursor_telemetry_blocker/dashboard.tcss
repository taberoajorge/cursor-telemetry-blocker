Screen {
    background: $surface;
}

Header {
    dock: top;
}

#stats_bar {
    dock: top;
    height: 3;
    padding: 1 2;
    background: $panel;
    content-align: center middle;
    text-style: bold;
    border-bottom: hkey $accent;
}

TabbedContent {
    height: 1fr;
    padding: 0;
}

ContentSwitcher {
    height: 1fr;
}

TabPane {
    padding: 0;
    height: 1fr;
}

RichLog {
    height: 1fr;
    padding: 0 1;
    scrollbar-size: 1 1;
    scrollbar-color: $text 30%;
    scrollbar-color-hover: $text 50%;
    scrollbar-color-active: $accent;
}

Footer {
    dock: bottom;
}
