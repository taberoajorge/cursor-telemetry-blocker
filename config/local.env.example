# Cursor Telemetry Blocker — local configuration
# Copy this file to config/local.env and edit as needed.
# These values are read by generate-launcher.sh and cursor-doctor.sh.

# PROXY_MODE controls how mitmproxy intercepts Cursor traffic.
#   local    — transparent interception via macOS Network Extension
#              (requires Homebrew mitmproxy, no proxy env vars needed)
#   explicit — HTTP proxy on port 18080, Cursor must be launched with
#              HTTP_PROXY / HTTPS_PROXY or --proxy-server flag
PROXY_MODE=local

# FILTER_LEVEL controls what the proxy does with intercepted traffic.
#   block   — block telemetry domains and gRPC paths, pass AI requests
#   deep    — block + strip repo names/paths from AI gRPC payloads
#   observe — log all traffic without blocking (for analysis)
FILTER_LEVEL=deep
